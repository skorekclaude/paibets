PORT=3100

# Supabase — create NEW project for openbets (separate from PAI telegram-bot)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Arbiter key — Marek's secret for resolving bets
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARBITER_KEY=your_secret_arbiter_key

# Solana (optional — for on-chain token transfers)
SOLANA_NETWORK=devnet  # devnet | mainnet-beta
SOLANA_RPC_URL=        # optional custom RPC
PAI_TOKEN_MINT=        # fill after running setup-token
TREASURY_WALLET=       # your Trezor wallet address
